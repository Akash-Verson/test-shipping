{"public/index.html":"<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"utf-8\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n    <meta name=\"viewport\" content=\"width=device-width,initial-scale=1.0\">\r\n    <link rel=\"icon\" href=\"<%= BASE_URL %>favicon.ico\">\r\n    <title>\r\n        <%= htmlWebpackPlugin.options.title %>\r\n    </title>\r\n    <link href=\"https://cdn.syncfusion.com/ej2/33.1.44/{{theme}}.css\" rel=\"stylesheet\">\r\n    <link href=\"https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css\" rel=\"stylesheet\" />\r\n</head>\r\n\r\n<body>\r\n    <noscript>\r\n        <strong>We're sorry but <%= htmlWebpackPlugin.options.title %> doesn't work properly without JavaScript enabled.\r\n        Please enable it to continue.</strong>\r\n    </noscript>\r\n    <div id=\"app\"></div>\r\n    <style>\r\n            .control-section\r\n            {\r\n                margin-top: 100px;\r\n            }\r\n    </style>\r\n    <!-- built files will be auto injected -->\r\n</body>\r\n\r\n</html>\r\n","src/App.vue":"<template>\r\n  <div class=\"control-section\">\r\n    <div class=\"form-container\">\r\n      <label class=\"form-label\" for=\"ps\">Page Size :</label>\r\n      <select id=\"ps\">\r\n        <option>Letter</option>\r\n        <option>Legal</option>\r\n        <option>A3</option>\r\n        <option selected>A4</option>\r\n        <option>A5</option>\r\n        <option>B4</option>\r\n        <option>B5</option>\r\n      </select>\r\n\r\n      <label class=\"form-label\" for=\"po\">Page Orientation :</label>\r\n      <select id=\"po\">\r\n        <option selected>Portrait</option>\r\n        <option>Landscape</option>\r\n      </select>\r\n\r\n      <label class=\"form-label\" for=\"pm\">Page Margin :</label>\r\n      <select id=\"pm\">\r\n        <option selected>No margin</option>\r\n        <option>Small</option>\r\n        <option>Large</option>\r\n      </select>\r\n\r\n      <label class=\"form-label\" for=\"pr\">Page Rotation :</label>\r\n      <select id=\"pr\">\r\n        <option selected>0</option>\r\n        <option>90</option>\r\n        <option>180</option>\r\n        <option>270</option>\r\n      </select>\r\n\r\n      <label class=\"form-label\">Pages Count :</label>\r\n      <div class=\"pages-inline\">\r\n        <input type=\"text\" readonly id=\"pageCount\" value=\"1\" />\r\n        <button id=\"addPage\" type=\"button\">Add Page</button>\r\n      </div>\r\n    </div>\r\n    <br />\r\n    <br />\r\n    <div>\r\n      <p>\r\n        Click the button to view a PDF document generated by JavaScript PDF Library. Please note that Adobe Reader or its\r\n        equivalent is required to view the resultant document.\r\n      </p>\r\n    </div>\r\n    <div class=\"actions\">\r\n      <button id=\"normalbtn\">Generate PDF</button>\r\n    </div>\r\n  </div>\r\n</template>\r\n<style scoped>\r\n  body {\r\n    font-family: Arial, sans-serif;\r\n    font-size: 14px;\r\n    margin: 24px;\r\n    color: #333;\r\n  }\r\n  .control-section {\r\n    max-width: none;\r\n  }\r\n  .control-section p {\r\n    margin-bottom: 16px;\r\n  }\r\n  .form-container {\r\n    display: grid;\r\n    grid-template-columns: 180px auto;\r\n    column-gap: 12px;\r\n    row-gap: 12px;\r\n    align-items: center;\r\n  }\r\n  .form-label {\r\n    text-align: left;\r\n    white-space: nowrap;\r\n  }\r\n  select,\r\n  input[type=\"text\"] {\r\n    width: 220px;\r\n    padding: 6px;\r\n    font-size: 14px;\r\n    box-sizing: border-box;\r\n  }\r\n  .pages-inline {\r\n    display: flex;\r\n    gap: 8px;\r\n    align-items: center;\r\n  }\r\n  .pages-inline input[type=\"text\"] {\r\n    width: 60px;\r\n    text-align: center;\r\n  }\r\n  .apply-transition {\r\n    margin-top: 20px;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 8px;\r\n  }\r\n  .actions {\r\n    margin-top: 16px;\r\n  }\r\n  button {\r\n    padding: 6px 12px;\r\n    font-size: 14px;\r\n    cursor: pointer;\r\n  }\r\n  .apply-transition input[type=\"checkbox\"] {\r\n    width: 20px;\r\n    height: 20px;\r\n    transform: scale(0.75);\r\n    cursor: pointer;\r\n  }\r\n</style>\r\n<script lang=\"ts\">\r\nimport { defineComponent, onMounted } from 'vue';\r\nimport { Button } from '@syncfusion/ej2-buttons';\r\nimport {\r\n  PdfDocument,\r\n  PdfPageSettings,\r\n  PdfMargins,\r\n  PdfPen,\r\n  PdfBrush,\r\n  PdfFontFamily,\r\n  PdfFontStyle,\r\n  PdfPageOrientation,\r\n  PdfRotationAngle\r\n} from '@syncfusion/ej2-pdf';\r\n\r\nexport default defineComponent({\r\n  name: 'PageSettingsPdf',\r\n  setup() {\r\n    onMounted(() => {\r\n      const genBtn = new Button({}, '#normalbtn');\r\n      const addBtn = new Button({}, '#addPage');\r\n\r\n      const addButton = document.getElementById('addPage') as HTMLButtonElement | null;\r\n      const pageCountEl = document.getElementById('pageCount') as HTMLInputElement | null;\r\n      if (addButton && pageCountEl) {\r\n        addButton.addEventListener('click', () => {\r\n          const current = parseInt(pageCountEl.value || '1', 10);\r\n          pageCountEl.value = String(Math.max(1, current + 1));\r\n        });\r\n      }\r\n      if (genBtn && genBtn.element) {\r\n        (genBtn.element as HTMLButtonElement).onclick = () => createPdf();\r\n      }\r\n    });\r\n\r\n    function createPdf(): void {\r\n      const { ps, po, pm, pr, pageCount } = readUI();\r\n      const settings = new PdfPageSettings();\r\n      const size = getPageSize(ps);\r\n      settings.size = size as any;\r\n      settings.orientation = po === 'Portrait' ? PdfPageOrientation.portrait : PdfPageOrientation.landscape;\r\n      settings.rotation = getRotationAngle(String(pr));\r\n      settings.margins = new PdfMargins(getMargin(pm));\r\n\r\n      const pdf = new PdfDocument();\r\n      const pen = new PdfPen({ r: 0, g: 0, b: 0 }, 6);\r\n      const lightGreenBrush = new PdfBrush({ r: 144, g: 238, b: 144 });\r\n      const textBrush = new PdfBrush({ r: 0, g: 0, b: 0 });\r\n      const footerFont = pdf.embedFont(PdfFontFamily.helvetica, 16, PdfFontStyle.regular);\r\n\r\n      for (let i = 0; i < pageCount; i++) {\r\n        const page = pdf.addPage(settings);\r\n        const g = page.graphics;\r\n        const client = g.clientSize;\r\n        g.drawRectangle({ x: 0, y: 0, width: client.width, height: client.height }, lightGreenBrush);\r\n        g.drawLine(pen, { x: 0, y: 100 }, { x: Math.min(300, client.width), y: 100 });\r\n        const footerText = `Page ${i + 1} of ${pageCount}`;\r\n        g.drawString(footerText, footerFont, { x: client.width - 150, y: client.height - 40, width: 140, height: 30 }, textBrush);\r\n      }\r\n\r\n      pdf.save('PageSettings.pdf');\r\n      pdf.destroy();\r\n    }\r\n\r\n    function getPageSize(name: string) {\r\n      const PAGE_SIZES: Record<string, { width: number; height: number }> = {\r\n        Letter: { width: 612, height: 792 },\r\n        Legal: { width: 612, height: 1008 },\r\n        A3: { width: 842, height: 1191 },\r\n        A4: { width: 595, height: 842 },\r\n        A5: { width: 420, height: 595 },\r\n        B4: { width: 729, height: 1032 },\r\n        B5: { width: 516, height: 729 }\r\n      };\r\n      const key = (name || '').trim();\r\n      return PAGE_SIZES[key] ?? PAGE_SIZES.A4;\r\n    }\r\n\r\n    function getMargin(name: string): number {\r\n      const key = (name || '').trim();\r\n      if (key === 'Small') return 20;\r\n      if (key === 'Large') return 40;\r\n      return 0;\r\n    }\r\n\r\n    function getRotationAngle(deg: string): PdfRotationAngle {\r\n      switch ((deg || '').trim()) {\r\n        case '90':\r\n          return PdfRotationAngle.angle90;\r\n        case '180':\r\n          return PdfRotationAngle.angle180;\r\n        case '270':\r\n          return PdfRotationAngle.angle270;\r\n        default:\r\n          return PdfRotationAngle.angle0;\r\n      }\r\n    }\r\n\r\n    function readUI() {\r\n      const ps = (document.getElementById('ps') as HTMLSelectElement)?.value ?? 'A4';\r\n      const po = (document.getElementById('po') as HTMLSelectElement)?.value ?? 'Portrait';\r\n      const pm = (document.getElementById('pm') as HTMLSelectElement)?.value ?? 'No margin';\r\n      const pr = (document.getElementById('pr') as HTMLSelectElement)?.value ?? '0';\r\n      const pageCount = parseInt((document.getElementById('pageCount') as HTMLInputElement)?.value ?? '1', 10);\r\n      return { ps, po, pm, pr, pageCount: Math.max(1, pageCount || 1) };\r\n    }\r\n\r\n    return {};\r\n  }\r\n});\r\n</script>","dependencies":"{\"vue\":\"3.3.4\",\"@syncfusion/ej2-base\":\"*\",\"markdown-spellcheck\":\"^1.3.1\",\"@syncfusion/ej2-buttons\":\"*\",\"@syncfusion/ej2-compression\":\"*\",\"@syncfusion/ej2-pdf\":\"*\"}","src/main.js":"import { createApp } from 'vue'\nimport App from './App.vue'\ncreateApp(App).mount('#app')"}